{
  "name": "sns-in-vscode",
  "version": "0.0.1",
  "private": true,
  "publisher": "rarkhopper",
  "displayName": "SNS in VS Code",
  "description": "Minimal Hello World VS Code extension package for workspace bootstrap.",
  "license": "MIT",
  "engines": {
    "node": ">=20.11.0",
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:snsInVscode.helloWorld"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "snsInVscode.helloWorld",
        "title": "SNS in VS Code: Hello World"
      }
    ]
  },
  "scripts": {
    "build": "rimraf dist && node esbuild.mjs",
    "dev": "node esbuild.mjs --watch",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --config vitest.config.ts"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/vscode": "^1.110.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.27.4",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  }
}
