{
  "name": "sns-in-vscode",
  "version": "0.0.1",
  "private": true,
  "publisher": "rarkhopper",
  "displayName": "SNS in VS Code",
  "description": "SNS timeline in your VS Code sidebar.",
  "license": "MIT",
  "engines": {
    "node": ">=20.11.0",
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:snsInVscode.timelineView"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "sns-in-vscode",
          "title": "SNS",
          "icon": "assets/icon.svg"
        }
      ]
    },
    "views": {
      "sns-in-vscode": [
        {
          "type": "webview",
          "id": "snsInVscode.timelineView",
          "name": "Timeline"
        }
      ]
    }
  },
  "scripts": {
    "build": "rimraf dist && node esbuild.mjs",
    "dev": "node esbuild.mjs --watch",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --config vitest.config.ts"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/vscode": "^1.110.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.27.4",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  }
}
