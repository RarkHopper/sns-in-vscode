{
  "name": "@sns-in-vscode/tui",
  "version": "0.0.1",
  "private": true,
  "description": "Ink-based TUI for sns-in-vscode",
  "license": "MIT",
  "type": "module",
  "bin": {
    "sns-tui": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "node --import tsx/esm src/index.tsx",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@sns-in-vscode/db": "workspace:*",
    "@sns-in-vscode/domain": "workspace:*",
    "ink": "^5.1.0",
    "ink-text-input": "^6.0.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
